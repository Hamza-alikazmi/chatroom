<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <script src="https://cdn.tailwindcss.com"></script>
  <title>Enter Secret Key</title>
</head>
<body class="bg-gray-100 flex items-center justify-center h-screen">
  <div class="bg-white p-8 rounded-xl shadow-lg w-full max-w-sm">
    <h1 class="text-2xl font-bold mb-6 text-center">Enter Secret Key</h1>
    <form action="/validate-secret" method="POST" class="flex flex-col gap-4">
      <input type="password" name="secret" placeholder="Secret Key" class="border p-2 rounded focus:ring-2 focus:ring-blue-400" required>
      <button type="submit" class="bg-blue-500 text-white py-2 rounded hover:bg-blue-600 transition">Proceed</button>
    </form>
  </div>
</body>
</html>
